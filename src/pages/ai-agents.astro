<Base title="AI Agents & Frameworks" description="Frameworks, tools, and infrastructure for building, deploying, and orchestrating AI agents.">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">AI Agents & Frameworks</h1>
      <p class="mt-2 text-text-secondary">Frameworks, tools, and infrastructure for building, deploying, and orchestrating AI agents — multi-agent systems, LLM coding assistants, MCP servers, memory layers, and orchestration platforms.</p>
    </div>
    <span class="text-sm font-semibold text-accent-violet">{projects.length} projects</span>
  </div>
  <FilterBar />
  <div class="space-y-4">
    {projects.map(p => <ProjectCard {...p} />)}
  </div>
</Base>
