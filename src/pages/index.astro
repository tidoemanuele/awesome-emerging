---
import Base from '../layouts/Base.astro';
import ProjectMiniCard from '../components/ProjectMiniCard.astro';
import { insights } from '../data/insights';

const base = import.meta.env.BASE_URL;

// ── Parse projects from raw category page sources at build time ──
const categoryFiles: Record<string, { glob: Record<string, string>; slug: string }> = {
  'ai-agents': { glob: import.meta.glob('./ai-agents.astro', { eager: true, as: 'raw' }), slug: 'ai-agents' },
  'cli-tools': { glob: import.meta.glob('./cli-tools.astro', { eager: true, as: 'raw' }), slug: 'cli-tools' },
  'developer-tools': { glob: import.meta.glob('./developer-tools.astro', { eager: true, as: 'raw' }), slug: 'developer-tools' },
  'open-source-infra': { glob: import.meta.glob('./open-source-infra.astro', { eager: true, as: 'raw' }), slug: 'open-source-infra' },
};

interface Project {
  name: string;
  url: string;
  description: string;
  discovered: string;
  signal: string;
  signalLevel: 'hot' | 'rising' | 'early';
  category: string;
  tags: string[];
}

function parseProjects(raw: string, category: string): Project[] {
  const projects: Project[] = [];
  // Split on project object boundaries (indented opening braces)
  const blocks = raw.split(/\n  \{/).slice(1);
  for (const rawBlock of blocks) {
    const block = '{' + rawBlock;
    const name = block.match(/name:\s*"([^"]*)"/)?.[1] || '';
    const url = block.match(/url:\s*"([^"]*)"/)?.[1] || '';
    const description = block.match(/description:\s*"([^"]*)"/)?.[1] || '';
    const discovered = block.match(/discovered:\s*"([^"]*)"/)?.[1] || '';
    const signal = block.match(/signal:\s*"([^"]*)"/)?.[1] || '';
    const signalLevelMatch = block.match(/signalLevel:\s*"([^"]*)"/)?.[1] || 'early';
    const tagsMatch = block.match(/tags:\s*\[([^\]]*)\]/)?.[1] || '';
    const tags = tagsMatch ? tagsMatch.match(/"([^"]*)"/g)?.map(t => t.replace(/"/g, '')) || [] : [];

    if (name && discovered) {
      projects.push({
        name, url, description, discovered, signal,
        signalLevel: signalLevelMatch as 'hot' | 'rising' | 'early',
        category, tags,
      });
    }
  }
  return projects;
}

// Parse all projects from all categories
const allProjects: Project[] = [];
const categoryCounts: Record<string, number> = {};

for (const [category, { glob, slug }] of Object.entries(categoryFiles)) {
  const raw = Object.values(glob)[0] || '';
  const projects = parseProjects(raw, slug);
  categoryCounts[slug] = projects.length;
  allProjects.push(...projects);
}

const totalCount = allProjects.length;

// Sort by discovered date descending
allProjects.sort((a, b) => b.discovered.localeCompare(a.discovered));

// Group projects by date
const projectsByDate = new Map<string, Project[]>();
for (const p of allProjects) {
  const list = projectsByDate.get(p.discovered) || [];
  list.push(p);
  projectsByDate.set(p.discovered, list);
}

// Get the most recent dates (show last 7 days of activity)
const recentDates = [...projectsByDate.keys()].slice(0, 7);

// Latest insights
const latestDay = insights[0];
const latestInsightEntries = latestDay.entries.slice(0, 5);
const latestInsightDate = new Date(latestDay.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

// Category metadata
const categoryMeta: Record<string, { label: string; icon: string; color: string }> = {
  'ai-agents': { label: 'AI Agents', icon: '🤖', color: 'bg-accent-violet/15 text-accent-violet border-accent-violet/25' },
  'cli-tools': { label: 'CLI Tools', icon: '💻', color: 'bg-accent-cyan/15 text-accent-cyan border-accent-cyan/25' },
  'developer-tools': { label: 'Dev Tools', icon: '🛠️', color: 'bg-accent-blue/15 text-accent-blue border-accent-blue/25' },
  'open-source-infra': { label: 'Infra', icon: '🌐', color: 'bg-signal-rising/15 text-signal-rising border-signal-rising/25' },
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}
---

<Base title="Home" description="A curated list of emerging open source projects that actually matter — signal-filtered, momentum-tracked, community-curated.">

  <!-- Compact Header -->
  <section class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold font-[family-name:var(--font-display)]">
        <span class="text-gradient">Awesome Emerging</span>
      </h1>
      <p class="text-sm text-text-muted mt-0.5">{totalCount} projects tracked &middot; Updated {latestInsightDate}</p>
    </div>
    <div class="flex gap-2">
      <a href={`${base}insights/`} class="px-3 py-1.5 text-xs font-semibold rounded-lg glass text-text-secondary hover:text-accent-violet transition-colors">Insights</a>
      <a href={`${base}about/`} class="px-3 py-1.5 text-xs font-semibold rounded-lg glass text-text-secondary hover:text-accent-violet transition-colors">About</a>
    </div>
  </section>

  <!-- Category Nav Pills -->
  <section class="flex flex-wrap gap-2 mb-6">
    {Object.entries(categoryMeta).map(([slug, meta]) => (
      <a href={`${base}${slug}/`} class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg border transition-all hover:scale-[1.02] ${meta.color}`}>
        <span>{meta.icon}</span>
        <span>{meta.label}</span>
        <span class="opacity-60">{categoryCounts[slug]}</span>
      </a>
    ))}
    <div class="flex items-center gap-3 ml-auto text-[11px] text-text-muted">
      <span class="inline-flex items-center gap-1">🔥 &gt;500pts / &gt;10K★</span>
      <span class="inline-flex items-center gap-1">⚡ &gt;100pts / &gt;1K★</span>
      <span class="inline-flex items-center gap-1">🌱 Early</span>
    </div>
  </section>

  <!-- Latest Insights Strip -->
  <section class="mb-5">
    <div class="flex items-center gap-2 mb-3">
      <span class="w-2 h-2 rounded-full bg-accent-violet"></span>
      <h2 class="text-sm font-semibold text-accent-violet">Insights &middot; {latestInsightDate}</h2>
      <a href={`${base}insights/`} class="ml-auto text-[11px] text-text-muted hover:text-accent-violet transition-colors">View all &rarr;</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-1.5">
      {latestInsightEntries.map(entry => (
        <div class="glass rounded-lg px-2.5 py-2 border-l-2 border-accent-violet/30">
          <p class="text-[11px] text-text-secondary leading-snug line-clamp-3">{entry}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Projects by Date -->
  {recentDates.map(date => {
    const projects = projectsByDate.get(date) || [];
    const dateLabel = formatDate(date);
    const hotCount = projects.filter(p => p.signalLevel === 'hot').length;
    const risingCount = projects.filter(p => p.signalLevel === 'rising').length;
    return (
      <section class="mb-5">
        <div class="flex items-center gap-3 mb-3 border-b border-border-subtle pb-2">
          <h2 class="text-sm font-semibold text-text-primary">{dateLabel}</h2>
          <span class="text-xs text-text-muted">{projects.length} projects</span>
          {hotCount > 0 && <span class="text-[11px] text-signal-hot">🔥 {hotCount}</span>}
          {risingCount > 0 && <span class="text-[11px] text-signal-rising">⚡ {risingCount}</span>}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2">
          {projects.map(p => (
            <ProjectMiniCard
              name={p.name}
              url={p.url}
              description={p.description}
              discovered={p.discovered}
              signal={p.signal}
              signalLevel={p.signalLevel}
              category={p.category}
              tags={p.tags}
            />
          ))}
        </div>
      </section>
    );
  })}

  <!-- View More -->
  <div class="text-center py-6 border-t border-border-subtle">
    <p class="text-xs text-text-muted mb-3">Showing {recentDates.length} most recent days &middot; {totalCount} total projects across {Object.keys(categoryCounts).length} categories</p>
    <div class="flex flex-wrap justify-center gap-2">
      {Object.entries(categoryMeta).map(([slug, meta]) => (
        <a href={`${base}${slug}/`} class="px-4 py-2 text-xs font-semibold rounded-lg glass text-text-secondary hover:text-accent-violet transition-colors">
          Browse all {meta.label} &rarr;
        </a>
      ))}
    </div>
  </div>
</Base>
