<Base title="Developer Tools" description="Tooling for the developer experience — package managers, runtime managers, AI-assisted code review, IDE integrations, and build systems.">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">Developer Tools</h1>
      <p class="mt-2 text-text-secondary">Tooling for the developer experience — package managers, runtime managers, AI-assisted code review, IDE integrations, build systems, and development workflow utilities.</p>
    </div>
    <span class="text-sm font-semibold text-accent-violet">{projects.length} projects</span>
  </div>
  <FilterBar />
  <div class="space-y-4">
    {projects.map(p => <ProjectCard {...p} />)}
  </div>
</Base>
