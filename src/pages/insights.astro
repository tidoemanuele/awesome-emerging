---

<Base title="Insights" description="Punchy takeaways from daily open source research — lessons learned, patterns spotted, signals that matter.">
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">Insights</h1>
    <p class="mt-2 text-text-secondary">Sharp takeaways from daily research. No fluff — just the signal.</p>
  </div>

  <div class="space-y-10">
    {insights.map(day => (
      <section>
        <h2 class="text-sm font-semibold text-accent-violet mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent-violet"></span>
          {day.date}
        </h2>
        <div class="space-y-3">
          {day.entries.map(entry => (
            <div class="glass rounded-[var(--radius-card)] p-4 border-l-2 border-accent-violet/40">
              <p class="text-sm text-text-secondary leading-relaxed">{entry}</p>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>
