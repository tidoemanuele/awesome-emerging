    description: "GPU-accelerated terminal emulator by Mitchell Hashimoto — 1.3.0 release strengthens the terminal-as-creative-surface for AI agent workflows.",
    discovered: "2026-03-10",
    signal: "32 Lobsters comments",
    signalLevel: "rising" as const,
  },
  {
    name: "Lightpanda",
    url: "https://github.com/lightpanda-io/browser",
