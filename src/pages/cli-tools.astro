    discovered: "2026-01-12",
    signal: "⭐ 16,617 stars (+2,100/day)",
    signalLevel: "hot" as const,
  },
  {
    name: "mcpc",
    url: "https://github.com/apify/mcp-cli",
    description: "Universal CLI client for Model Context Protocol servers.",
    discovered: "2026-01-14",
    signal: "50 HN points",
    signalLevel: "early" as const,
    tags: ["mcp", "open-source", "cli"],
  },
  {
    name: "Nudge",
    url: "https://github.com/attunehq/nudge",
