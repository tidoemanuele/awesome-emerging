    discovered: "2026-01-12",
    signal: "513 HN points",
    signalLevel: "hot" as const,
    tags: ["open-source"],
  },
  {
    name: "yolo-cage",
    url: "https://github.com/borenstein/yolo-cage",
    description: "Sandboxed agent execution environment with containment controls.",
    discovered: "2026-01-14",
    signal: "52 HN points",
    signalLevel: "early" as const,
    tags: ["agent", "security", "open-source"],
  },
  {
    name: "SiteSpy",
    url: "",
    description: "Webpage watcher that exposes changes as RSS feeds — monitor competitors, libraries, documentation changes. CLI-first design with RSS output for pipeline integration.",
    discovered: "2026-03-12",
    signal: "222 HN points",
    signalLevel: "rising" as const,
    tags: ["cli", "open-source"],
  },
  {
    name: "fish-speech",
    url: "https://github.com/fishaudio/fish-speech",
    description: "State-of-the-art open-source text-to-speech — Python-based with CLI for batch processing. Core audio generation node in creative pipelines. 27,085 stars, sustained +377/day.",
    discovered: "2026-03-12",
    signal: "⭐ 27,085 stars (+377/day)",
    signalLevel: "hot" as const,
    tags: ["open-source", "cli"],
  },
  {
    name: "Autoresearch@home",
    url: "",
    description: "Distributed research framework using the BOINC/@home paradigm — volunteer computing for AI research tasks. CLI-native with local research agents contributing to shared findings.",
    discovered: "2026-03-12",
    signal: "62 HN points",
    signalLevel: "early" as const,
    tags: ["open-source", "cli"],
  },
].sort((a, b) => b.discovered.localeCompare(a.discovered));
---

<Base title="CLI Tools" description="Command-line utilities and terminal-based tools for developer workflows and AI agent execution.">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">CLI Tools</h1>
      <p class="mt-2 text-text-secondary">Command-line utilities and terminal-based tools — headless browsers for agent scraping, sandboxed execution environments, debugging aids, and developer CLI utilities.</p>
    </div>
    <span class="text-sm font-semibold text-accent-violet">{projects.length} projects</span>
  </div>
  <FilterBar />
  <div class="space-y-4">
    {projects.map(p => <ProjectCard {...p} />)}
  </div>
</Base>
