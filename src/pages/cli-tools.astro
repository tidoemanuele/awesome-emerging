---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import FilterBar from '../components/FilterBar.astro';

const projects = [
  {
    name: "audiowmark",
    url: "https://github.com/swesterfeld/audiowmark",
    description: "Audio watermarking CLI — embed invisible watermarks in audio that survive format conversion, compression, and speed changes. Key tool for AI-generated content provenance.",
    discovered: "2026-03-11",
    signal: "Lobsters discussion",
    signalLevel: "early" as const,
    tags: ["open-source", "cli"],
  },
  {
    name: "Agent-FUSE",
    url: "https://github.com/Jakob-em/agent-fuse",
    description: "FUSE-based virtual filesystem for AI agents — mount agent outputs as a navigable directory.",
    discovered: "2026-01-12",
    signal: "513 HN points",
    signalLevel: "hot" as const,
    tags: ["agent", "open-source"],
  },
  {
    name: "claude-code-supervisor",
    url: "https://github.com/guyskk/claude-code-supervisor",
    description: "Auto-review supervisor for Claude Code — catches mistakes before commit.",
    discovered: "2026-01-14",
    signal: "50 HN points",
    signalLevel: "early" as const,
    tags: ["open-source"],
  },
  {
    name: "Ghostty",
