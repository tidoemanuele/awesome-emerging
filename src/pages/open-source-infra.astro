---

<Base title="Open Source Infrastructure" description="Open-source infrastructure projects, networking tools, alternative platforms, and foundational software with significant community traction.">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">Open Source Infrastructure</h1>
      <p class="mt-2 text-text-secondary">Open-source infrastructure projects, networking tools, alternative platforms, and foundational software with significant community traction.</p>
    </div>
    <span class="text-sm font-semibold text-accent-violet">{projects.length} projects</span>
  </div>
  <div class="space-y-4">
    {projects.map(p => <ProjectCard {...p} />)}
  </div>
</Base>
