    discovered: "2026-02-02",
    signal: "636 HN points",
    signalLevel: "hot" as const,
  },
  {
    name: "openclaw",
    url: "https://github.com/openclaw/openclaw",
    description: "Open-source macOS AI assistant — community alternative to Apple Intelligence.",
    discovered: "2026-01-31",
    signal: "Early / untracked",
    signalLevel: "early" as const,
    tags: ["open-source"],
  },
  {
    name: "PageIndex",
    url: "https://github.com/VectifyAI/PageIndex",
