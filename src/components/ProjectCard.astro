---
interface Props {
  name: string;
  url: string;
  description: string;
  discovered: string;
  signal: string;
  signalLevel: 'hot' | 'rising' | 'early';
  tags?: string[];
}

const { name, url, description, discovered, signal, signalLevel, tags = [] } = Astro.props;

const signalColors = {
  hot: 'text-signal-hot',
  rising: 'text-signal-rising',
  early: 'text-text-muted',
};

const signalEmoji = {
  hot: '🔥',
  rising: '⚡',
  early: '🌱',
};
---

<article class="group glass rounded-[var(--radius-card)] p-5 transition-all duration-300 hover:glow-accent hover:border-accent-violet/30 project-card" data-discovered={discovered}>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      {url ? (
        <a href={url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-lg font-semibold font-[family-name:var(--font-display)] text-text-primary hover:text-gradient transition-colors">
          {name}
          <svg class="w-4 h-4 text-text-muted opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>
      ) : (
        <span class="inline-flex items-center gap-2 text-lg font-semibold font-[family-name:var(--font-display)] text-text-primary">
          {name}
          <span class="text-xs text-text-muted font-normal">(link unverified)</span>
        </span>
      )}
      <p class="mt-1 text-sm text-text-secondary leading-relaxed">{description}</p>
    </div>
    <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full border ${
      signalLevel === 'hot' ? 'border-signal-hot/30 bg-signal-hot/10 text-signal-hot' :
      signalLevel === 'rising' ? 'border-signal-rising/30 bg-signal-rising/10 text-signal-rising' :
      'border-border-default bg-surface-raised text-text-muted'
    }`}>
      {signalEmoji[signalLevel]} {signalLevel.charAt(0).toUpperCase() + signalLevel.slice(1)}
    </span>
  </div>
  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-text-muted">
    <span>Discovered {discovered}</span>
    <span class={signalColors[signalLevel]}>{signal}</span>
  </div>
  {tags.length > 0 && (
    <div class="mt-2.5 flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="px-2 py-0.5 text-xs rounded-full bg-accent-violet/10 text-accent-violet border border-accent-violet/20">
          {tag}
        </span>
      ))}
    </div>
  )}
</article>
