---
interface Props {
  title: string;
  description: string;
  count: number;
  href: string;
  icon: string;
}

const { title, description, count, href, icon } = Astro.props;
---

<a href={href} class="group glass rounded-[var(--radius-card)] p-6 transition-all duration-300 hover:glow-accent hover:border-accent-violet/30 block">
  <div class="text-3xl mb-3">{icon}</div>
  <h3 class="text-lg font-bold font-[family-name:var(--font-display)] text-text-primary group-hover:text-gradient transition-colors">
    {title}
  </h3>
  <p class="mt-1 text-sm text-text-secondary leading-relaxed">{description}</p>
  <div class="mt-3 flex items-center justify-between">
    <span class="text-xs font-semibold text-accent-violet">{count} projects</span>
    <svg class="w-4 h-4 text-text-muted group-hover:text-accent-cyan transition-all group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </div>
</a>
